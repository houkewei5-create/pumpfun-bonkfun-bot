# Environment Variables Configuration

# ===== Solana RPC Configuration =====
# Required: Your Solana RPC endpoint
# Free options: https://api.mainnet-beta.solana.com (slow)
# Better: Use private RPC from:
#   - Chainstack: https://console.chainstack.com/
#   - Helius: https://www.helius.dev/
#   - QuickNode: https://www.quicknode.com/
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ===== Wallet Configuration =====
# Your Solana wallet private key (base58 format)
# Get from: solana config get
# IMPORTANT: Use a BURNER wallet, not your main wallet!
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ===== API Keys =====
# GMGN API key (for token data and trends)
# Get from: https://gmgn.ai/
GMGN_API_KEY=your_gmgn_api_key_here

# DexScreener API (optional, for supplementary data)
DEXSCREENER_API_KEY=optional_dexscreener_api_key

# ===== Optional: Telegram Alerts =====
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Your Telegram chat ID
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===== Trading Mode =====
# true = Paper trading (simulation)
# false = Live trading (REAL MONEY)
PAPER_TRADING=true

# Amount to trade per position (SOL)
TRADE_AMOUNT_SOL=0.01

# ===== Logging =====
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===== Advanced (Optional) =====
# Jito bundle endpoint
JITO_ENDPOINT=https://amsterdam.mainnet.block-engine.jito.wtf
JITO_TIP_LAMPORTS=50000

# Max RPS (requests per second) to RPC
MAX_RPS=25
